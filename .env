# ─── AZURE SQL DATABASE ────────────────────────────────────────────────────────
# Your Azure SQL Server FQDN — found in Azure Portal → SQL Server → Overview
DB_SERVER=kg-summer-of-69.database.windows.net
DB_PORT=1433
DB_NAME=alert-workflow-ai
DB_USER=sql-admin
DB_PASSWORD=Weiningen@10
DB_CONNECTION_LIMIT=10

# ─── AUTH ─────────────────────────────────────────────────────────────────────
# Generate a strong secret:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=REPLACE_WITH_A_STRONG_RANDOM_SECRET_AT_LEAST_64_CHARS
JWT_EXPIRES_IN=8h

# ─── SERVER ───────────────────────────────────────────────────────────────────
PORT=4000
ALLOWED_ORIGINS=http://localhost:3000

# ─── DATASOURCE MODE ──────────────────────────────────────────────────────────
# "mock"      → React uses in-memory data (no DB, no server needed)
# "azure-sql" → React calls Express API which queries Azure SQL Server
REACT_APP_DATASOURCE=azure-sql
